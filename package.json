{
  "name": "pxg-siteworks",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx @tailwindcss/cli -i src/styles/input.css -o public/static/tailwind.css --minify && vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name pxg-siteworks",
    "dev:sandbox": "wrangler pages dev dist --d1=pxg_siteworks --local --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply pxg_siteworks --local",
    "db:migrate:prod": "wrangler d1 migrations apply pxg_siteworks",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
